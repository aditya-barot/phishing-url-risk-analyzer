# Example environment configuration for Phishing URL Risk Analyzer
#
# Copy this file to `.env` and fill in real values as needed.
# `.env` is git-ignored and must never be committed.
#
# No secrets are required for the current milestone. These are placeholders
# for future configuration (e.g., logging level, optional feature flags).

# Logging verbosity: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO